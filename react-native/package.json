{
  "name": "@goldenkrill/react-native",
  "version": "0.9.0",
  "description": "Golden Krill cross-promotion (house ads) SDK for React Native. Fills paid-ad no-fill with a cross-promo for another participating app.",
  "license": "Apache-2.0",
  "homepage": "https://golden-krill.com",
  "repository": "https://github.com/PinkRorqual/golden-krill-sdk",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": ["src"],
  "keywords": ["react-native", "ads", "cross-promotion", "house-ads", "goldenkrill"],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "@types/jest": "^29.5.12",
    "react": "^18.2.0",
    "react-test-renderer": "^18.2.0",
    "@types/react": "^18.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "testMatch": ["**/*.test.ts", "**/*.test.tsx"],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/test/_rn_stub.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": { "module": "commonjs", "esModuleInterop": true, "strict": false, "skipLibCheck": true, "jsx": "react-jsx", "isolatedModules": true } }]
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/index.ts",
      "!src/debug.ts",
      "!src/endpoints.ts"
    ]
  }
}
